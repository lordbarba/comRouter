<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    <!-- jbTechnology GitHub Packages: LicenseManager.Sdk e JBFormLibrary -->
    <add key="github-jbtechnology" value="https://nuget.pkg.github.com/lordbarba/index.json" protocolVersion="3" />
  </packageSources>

  <!--
    Credenziali NON memorizzate qui. Ogni sviluppatore deve registrarle una sola volta con:
      dotnet nuget update source github-jbtechnology
             -u GITHUB_USER -p PAT_TOKEN
    Scope PAT richiesti: read:packages
  -->
</configuration>
